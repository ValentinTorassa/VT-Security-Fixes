 gdcm (3.0.22-2.1ubuntu1) noble; urgency=medium
 
   * Update testsuite for new renamed binary
diff -Nru gdcm-3.0.22/debian/patches/CVE-2025-11266.patch gdcm-3.0.22/debian/patches/CVE-2025-11266.patch
--- gdcm-3.0.22/debian/patches/CVE-2025-11266.patch	1970-01-01 00:00:00.000000000 +0000
+++ gdcm-3.0.22/debian/patches/CVE-2025-11266.patch	2026-07-02 23:43:40.000000000 +0000
@@ -0,0 +1,24 @@
+Description: Fix CVE-2025-11266 OOB write in DICOM parser
+ An out-of-bounds write vulnerability exists in GDCM during parsing
+ of malformed DICOM files containing encapsulated PixelData fragments.
+ When GetLength() returns less than 3, an unsigned integer underflow
+ causes out-of-bounds buffer access. Add length check before accessing.
+Origin: upstream, https://github.com/malaterre/GDCM/commit/5829c95c8ac3afa9a3a3413675e948959c28a789
+Bug-Ubuntu: https://bugs.launchpad.net/ubuntu/+source/gdcm/+bug/2157578
+Bug-Debian: https://bugs.debian.org/1122862
+Applied-Upstream: 3.2.2
+Forwarded: not-needed
+Last-Update: 2026-06-23
+---
+This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
+--- a/Source/DataStructureAndEncodingDefinition/gdcmSequenceOfFragments.h
++++ b/Source/DataStructureAndEncodingDefinition/gdcmSequenceOfFragments.h
+@@ -237,7 +237,7 @@ std::istream& ReadValue(std::istream &is, bool /*readvalues*/)
+       const size_t lastf = Fragments.size() - 1;
+       const ByteValue *bv = Fragments[ lastf ].GetByteValue();
+       const char *a = bv->GetPointer();
+-      gdcmAssertAlwaysMacro( (unsigned char)a[ bv->GetLength() - 3 ] == 0xfe );
++      gdcmAssertAlwaysMacro( bv->GetLength() >= 3 && (unsigned char)a[ bv->GetLength() - 3 ] == 0xfe );
+       Fragments[ lastf ].SetByteValue( bv->GetPointer(), bv->GetLength() - 3 );
+       is.seekg( -11, std::ios::cur );
+       assert( is.good() );
diff -Nru gdcm-3.0.22/debian/patches/series gdcm-3.0.22/debian/patches/series
--- gdcm-3.0.22/debian/patches/series	2023-12-07 09:17:36.000000000 +0000
+++ gdcm-3.0.22/debian/patches/series	2026-07-02 23:43:40.000000000 +0000
@@ -4,3 +4,4 @@
